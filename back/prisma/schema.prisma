// NeWell RMS — Prisma Schema
// Stack: PostgreSQL (Supabase) · Prisma ORM · Node.js / Express.js
// Run migrations: npx prisma migrate dev
// Generate client: npx prisma generate

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────────────────

enum UserRole {
  OWNER
  ADMIN
  COBRADOR
  TENANT
}

enum PropStatus {
  OCCUPIED
  EMPTY
  RESERVED
  RTO
  SOLD
  ARCHIVED
}

enum ContractType {
  REGULAR
  RTO
}

enum ContractStatus {
  ACTIVE
  EXPIRED
  RENEWED
  CANCELLED
}

enum PaymentStatus {
  PAID_ON_TIME
  PAID_LATE
  PARTIAL
  PENDING
  NOT_APPLICABLE
}

enum PaymentMethod {
  HEMLANE
  MONEY_ORDER
  CASH
  CHECK
  ZELLE_MIKE
  ZELLE_NADER
}

enum AlertSeverity {
  RED
  YELLOW
  GREEN
}

enum AlertType {
  CONTRACT_EXPIRING
  CONTRACT_EXPIRED
  PAYMENT_OVERDUE
  PROPERTY_VACANT
}

// ─────────────────────────────────────────────────────────────────────────────
// MODELS
// ─────────────────────────────────────────────────────────────────────────────

// Profiles of system users. Supabase Auth handles authentication;
// this table stores role and system-level data.
model UserProfile {
  id          String    @id @default(cuid())
  supabaseUid String    @unique
  name        String
  email       String    @unique
  role        UserRole
  tenantId    String?   @unique   // only set if role = TENANT
  isActive    Boolean   @default(true)
  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant    Tenant?      @relation(fields: [tenantId], references: [id])
  notes     TenantNote[] @relation("NoteAuthor")
  auditLogs AuditLog[]

  @@index([supabaseUid])
  @@index([role])
}

// Real estate properties managed by MJ Newell Homes.
// Central entity — everything anchors here.
model Property {
  id           String       @id @default(cuid())
  address      String
  houseModel   String       // LANGDON | EMELIA | NINA | AURORA | DELANIE | VIANA | LOUSIANA | DUPLEX | RENTA_VARIABLE
  city         String       // LABELLE | LEHIGH (extensible)
  baseRent     Decimal      @db.Decimal(10, 2)
  status       PropStatus   @default(EMPTY)
  contractType ContractType @default(REGULAR)
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  tenants        Tenant[]
  contracts      Contract[]
  paymentRecords PaymentRecord[]

  @@index([city])
  @@index([status])
  @@index([isActive])
}

// Tenants (arrendatarios). displayName supports multiple holders
// e.g. "Nicole Rosito AND Magdalena Solomonides"
model Tenant {
  id               String         @id @default(cuid())
  supabaseUid      String?        @unique  // set when tenant activates account
  displayName      String
  email            String         @unique
  phone            String?
  propertyId       String
  moveInDate       DateTime       @db.Date
  rentAmount       Decimal        @db.Decimal(10, 2)
  preferredPayment PaymentMethod?
  notes            String?        // internal notes — NEVER visible to TENANT role
  isActive         Boolean        @default(true)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  property       Property        @relation(fields: [propertyId], references: [id])
  userProfile    UserProfile?
  contracts      Contract[]
  paymentRecords PaymentRecord[]
  tenantNotes    TenantNote[]

  @@index([propertyId])
  @@index([isActive])
  @@index([email])
}

// Contracts and renewals. The self-reference via parentContractId
// chains the full renewal history: Contract#1 ← Contract#2 ← Contract#3
model Contract {
  id               String         @id @default(cuid())
  tenantId         String
  propertyId       String
  type             ContractType
  startDate        DateTime       @db.Date
  durationYears    Int
  endDate          DateTime       @db.Date  // calculated: startDate + durationYears
  status           ContractStatus @default(ACTIVE)
  renewalNumber    Int            @default(0) // 0 = original, 1 = first renewal, etc.
  parentContractId String?                    // NULL for originals
  alertSentAt      DateTime?                  // avoid sending duplicate alerts
  notes            String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  tenant         Tenant          @relation(fields: [tenantId], references: [id])
  property       Property        @relation(fields: [propertyId], references: [id])
  parentContract Contract?       @relation("Renewals", fields: [parentContractId], references: [id])
  renewals       Contract[]      @relation("Renewals")
  rtoDetail      RTODetail?
  paymentRecords PaymentRecord[]

  @@index([tenantId])
  @@index([propertyId])
  @@index([status])
  @@index([endDate])
}

// Extra fields for RTO contracts. 1:1 with Contract.
// The balance towards the purchase is calculated dynamically:
// initialDeposit + (optionAgreementMonthly × monthsPaid)
model RTODetail {
  id                     String    @id @default(cuid())
  contractId             String    @unique
  purchasePrice          Decimal   @db.Decimal(12, 2)
  egsFee                 Decimal   @db.Decimal(10, 2) @default(0)
  totalSalePrice         Decimal   @db.Decimal(12, 2)  // purchasePrice + egsFee
  optionAgreementMonthly Decimal   @db.Decimal(8, 2)   @default(300)
  initialDeposit         Decimal   @db.Decimal(10, 2)  @default(0)
  ceaseRentalDate        DateTime? @db.Date
  closingDate            DateTime? @db.Date

  contract Contract @relation(fields: [contractId], references: [id])
}

// Monthly payment record per tenant — digital equivalent of one row
// in the Google Sheets. One record per tenant per billing month.
// rentAmount is a snapshot: immutable once created.
model PaymentRecord {
  id               String         @id @default(cuid())
  tenantId         String
  propertyId       String
  contractId       String?        // contract active at time of payment; NULL for migrated history
  billingMonth     Int            // 1–12, independent of when money was received
  billingYear      Int
  rentAmount       Decimal        @db.Decimal(10, 2) // snapshot of rent for this month
  securityDeposit  Decimal        @db.Decimal(10, 2) @default(0)
  lastMonthDeposit Decimal        @db.Decimal(10, 2) @default(0)
  lateFeesAmount   Decimal        @db.Decimal(10, 2) @default(0)
  amountPaid       Decimal        @db.Decimal(10, 2) @default(0)
  pendingBalance   Decimal        @db.Decimal(10, 2) @default(0)
  paymentStatus    PaymentStatus  @default(PENDING)
  paymentDate      DateTime?      @db.Date
  receivedBy       String?
  paymentMethod    PaymentMethod?
  depositConfirmed Boolean        @default(false)
  notes            String?
  createdBy        String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  tenant       Tenant               @relation(fields: [tenantId], references: [id])
  property     Property             @relation(fields: [propertyId], references: [id])
  contract     Contract?            @relation(fields: [contractId], references: [id])
  transactions PaymentTransaction[]

  @@unique([tenantId, billingMonth, billingYear])
  @@index([propertyId])
  @@index([billingMonth, billingYear])
  @@index([paymentStatus])
}

// Individual payment transactions (partial payments, multiple payments in one month)
// Sum of transactions = PaymentRecord.amountPaid
model PaymentTransaction {
  id              String        @id @default(cuid())
  paymentRecordId String
  amount          Decimal       @db.Decimal(10, 2)
  transactionDate DateTime      @db.Date
  paymentMethod   PaymentMethod
  receivedBy      String?
  notes           String?
  createdAt       DateTime      @default(now())

  paymentRecord PaymentRecord @relation(fields: [paymentRecordId], references: [id])

  @@index([paymentRecordId])
}

// Internal notes about a tenant, written by admin/owner.
// TENANT role must never see these.
model TenantNote {
  id         String   @id @default(cuid())
  tenantId   String
  content    String
  authorId   String
  authorName String   // denormalized for audit history
  createdAt  DateTime @default(now())

  tenant Tenant      @relation(fields: [tenantId], references: [id])
  author UserProfile @relation("NoteAuthor", fields: [authorId], references: [id])

  @@index([tenantId])
}

// Late fee formula configuration. Editable from the admin panel
// without touching code. isActive = true means this config is in effect.
model LateFeeConfig {
  id              String   @id @default(cuid())
  name            String
  gracePeriodDays Int      @default(3)    // days 1-3: no charge
  flatFeeDay4     Decimal  @db.Decimal(8, 2) @default(42.00)   // charged on day 4
  dailyFeeAfter   Decimal  @db.Decimal(8, 2) @default(11.35)   // charged each day after day 4
  effectiveFrom   DateTime @default(now())
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
}

// Global key-value configuration store.
// Used for: collector list, payment methods, alert thresholds, etc.
model SystemConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// System-generated alerts shown in the dashboard.
model AlertNotification {
  id         String        @id @default(cuid())
  type       AlertType
  entityType String        // "Contract" | "Tenant" | "Property"
  entityId   String
  severity   AlertSeverity
  message    String
  isRead     Boolean       @default(false)
  resolvedAt DateTime?
  createdAt  DateTime      @default(now())

  @@index([isRead])
  @@index([severity])
  @@index([type])
}

// Full audit trail: who changed what and when.
model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  entityType String
  entityId   String
  action     String   // "CREATE" | "UPDATE" | "DELETE" | "STATUS_CHANGE"
  oldValue   Json?
  newValue   Json?
  createdAt  DateTime @default(now())

  user UserProfile @relation(fields: [userId], references: [id])

  @@index([entityType, entityId])
  @@index([userId])
  @@index([createdAt])
}
