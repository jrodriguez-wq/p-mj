# Copia a .env y rellena con los valores de tu proyecto Supabase
# Dashboard: https://supabase.com/dashboard/project/syzescxifgciygmvzjki/settings/api
# SUPABASE_ANON_KEY = clave "anon" "public" en API (JWT larga), no la contraseña de la DB

SUPABASE_URL=https://syzescxifgciygmvzjki.supabase.co
SUPABASE_ANON_KEY=tu-anon-key-jwt-aqui

# Connect to Supabase via connection pooling
DATABASE_URL="postgresql://postgres.syzescxifgciygmvzjki:EXAMPLE_PASSWORD@aws-0-us-west-2.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection to the database. Used for migrations
DIRECT_URL="postgresql://postgres.syzescxifgciygmvzjki:EXAMPLE_PASSWORD@aws-0-us-west-2.pooler.supabase.com:5432/postgres"
